    <form     name="loginform" method="POST" action="/dologin.action" class="aui login-form-container" >

                                                                                                    
                    <h2>登录</h2>

                                        
<div id="action-messages">
                        </div>
                    <fieldset class="compact-form-fields">
                            

    <legend class="assistive"><span>登录到 Confluence</span></legend>
                        

<div class="field-group
    "
        >
    <label id="os_username-label" for="os_username">
    <u>U</u>用户名
        </label>

                <input type="text" name="os_username" id="os_username"                                   class="text   "               placeholder="用户名"     data-focus="0"     />
                      </div>                        

<div class="field-group">
    <label id="os_password-label" for="os_password">
    <u>P</u>密码
        </label>
    <input type="password" name="os_password" id="os_password"                                   class="password "               placeholder="密码"          />
                  </div>                        
                                                    

<div class="group">
        
<div class="checkbox">
    <input type="checkbox" class="checkbox" value="true" name="os_cookie"
                id="os_cookie">
    <label for="os_cookie"><u>R</u>记住我的登录信息</label>
    </div>
</div>                                                <div class="field-group form-buttons compact-form-buttons">
                            <input id="loginButton" class="aui-button aui-style aui-button-primary" name="login" type="submit" value="登录"/>
                                                            <a id="forgot-password" class="aui-button aui-style aui-button-link" href="/forgotuserpassword.action">忘记密码</a>
                                                    </div>
                        <input type="hidden" name="os_destination" value="/download/attachments/10067755/image2019-3-13%2015:47:11.png?version=1"/>
                    </fieldset>
                                    

</form>                </div> 
